{
  "functions": {
    "api/*.js": {
      "memory": 256,
      "maxDuration": 15
    }
  },
  "routes": [
    {
      "src": "/api/flutterwave-webhook",
      "dest": "/api/flutterwave-webhook.js",
      "methods": ["POST"]
    },
    { "src": "/api/(.*)", "dest": "/api/$1.js" },
    { "src": "/(.*)",     "dest": "/$1" }
  ]
}
